{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lesson Plan Package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "date",
    "lesson_type",
    "source_deck",
    "sessions",
    "appendix",
    "metadata"
  ],
  "properties": {
    "date": {
      "type": "string",
      "minLength": 1
    },
    "lesson_type": {
      "type": "string",
      "minLength": 1
    },
    "source_deck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_file",
        "source_filename",
        "deck_title",
        "lesson_topic",
        "selected_session_numbers"
      ],
      "properties": {
        "source_file": {
          "type": "string",
          "minLength": 1
        },
        "source_filename": {
          "type": "string",
          "minLength": 1
        },
        "deck_title": {
          "type": "string",
          "minLength": 1
        },
        "lesson_topic": {
          "type": "string",
          "minLength": 1
        },
        "selected_session_numbers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "sessions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sessionPlan"
      }
    },
    "appendix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/appendixEntry"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "grade",
        "subject",
        "agenda_used",
        "requested_session_numbers",
        "generated_docx_filenames"
      ],
      "properties": {
        "grade": {
          "type": "string"
        },
        "subject": {
          "type": "string"
        },
        "agenda_used": {
          "type": "boolean"
        },
        "requested_session_numbers": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "generated_docx_filenames": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "$defs": {
    "sourceList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "integer",
        "minimum": 1
      }
    },
    "phaseSection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "section_title",
        "time_minutes",
        "focus_tasks",
        "teacher_actions",
        "student_actions",
        "evidence_of_learning",
        "misconceptions_to_monitor",
        "embedded_supports",
        "source_slide_numbers",
        "source_excerpt"
      ],
      "properties": {
        "section_title": {
          "type": "string",
          "minLength": 1
        },
        "time_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "focus_tasks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "teacher_actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "student_actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_of_learning": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "misconceptions_to_monitor": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "embedded_supports": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "source_slide_numbers": {
          "$ref": "#/$defs/sourceList"
        },
        "source_excerpt": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "spedSupport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "student",
        "supports"
      ],
      "properties": {
        "student": {
          "type": "string",
          "minLength": 1
        },
        "supports": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "sessionPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_label",
        "session_number",
        "output_filename",
        "lesson_information",
        "standards_and_learning_targets",
        "lesson_objective_and_student_success_criteria",
        "materials_and_preparation",
        "opening_warm_up_launch",
        "mini_lesson_modeling_concept_development",
        "guided_practice_collaborative_learning",
        "independent_practice_application_stations",
        "closure_exit_ticket_assessment",
        "differentiation_sped_esol_supports_and_teacher_notes"
      ],
      "properties": {
        "session_label": {
          "type": "string",
          "minLength": 1
        },
        "session_number": {
          "type": "integer",
          "minimum": 1
        },
        "output_filename": {
          "type": "string",
          "minLength": 1
        },
        "lesson_information": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "date",
            "lesson_title",
            "session_number",
            "session_label",
            "course_or_grade",
            "estimated_duration_minutes",
            "lesson_type",
            "source_slide_numbers"
          ],
          "properties": {
            "date": {
              "type": "string",
              "minLength": 1
            },
            "lesson_title": {
              "type": "string",
              "minLength": 1
            },
            "session_number": {
              "type": "integer",
              "minimum": 1
            },
            "session_label": {
              "type": "string",
              "minLength": 1
            },
            "course_or_grade": {
              "type": "string",
              "minLength": 1
            },
            "estimated_duration_minutes": {
              "type": "integer",
              "minimum": 1
            },
            "lesson_type": {
              "type": "string",
              "minLength": 1
            },
            "source_slide_numbers": {
              "$ref": "#/$defs/sourceList"
            }
          }
        },
        "standards_and_learning_targets": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "standards",
            "standards_status",
            "standards_source",
            "learning_targets",
            "i_can_statements"
          ],
          "properties": {
            "standards": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "standards_status": {
              "type": "string"
            },
            "standards_source": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "slide_numbers",
                "source_lines"
              ],
              "properties": {
                "slide_numbers": {
                  "type": "array",
                  "items": {
                    "type": "integer",
                    "minimum": 1
                  }
                },
                "source_lines": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            },
            "learning_targets": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "i_can_statements": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "lesson_objective_and_student_success_criteria": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "lesson_objective",
            "student_success_criteria"
          ],
          "properties": {
            "lesson_objective": {
              "type": "string",
              "minLength": 1
            },
            "student_success_criteria": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "materials_and_preparation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "materials",
            "preparation_notes",
            "required_visuals"
          ],
          "properties": {
            "materials": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "preparation_notes": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "required_visuals": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "opening_warm_up_launch": {
          "$ref": "#/$defs/phaseSection"
        },
        "mini_lesson_modeling_concept_development": {
          "$ref": "#/$defs/phaseSection"
        },
        "guided_practice_collaborative_learning": {
          "$ref": "#/$defs/phaseSection"
        },
        "independent_practice_application_stations": {
          "$ref": "#/$defs/phaseSection"
        },
        "closure_exit_ticket_assessment": {
          "$ref": "#/$defs/phaseSection"
        },
        "differentiation_sped_esol_supports_and_teacher_notes": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "implementation_note",
            "sped",
            "esol",
            "teacher_notes",
            "precision_monitoring"
          ],
          "properties": {
            "implementation_note": {
              "type": "string",
              "minLength": 1
            },
            "sped": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/spedSupport"
              }
            },
            "esol": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "teacher_notes": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "precision_monitoring": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "appendixEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slide_number",
        "title",
        "source_excerpt",
        "used_in_sections",
        "mapping_note"
      ],
      "properties": {
        "slide_number": {
          "type": "integer",
          "minimum": 1
        },
        "title": {
          "type": "string"
        },
        "source_excerpt": {
          "type": "string"
        },
        "used_in_sections": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mapping_note": {
          "type": "string"
        }
      }
    }
  }
}
